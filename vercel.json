{
  "version": 2,
  "functions": {
    "crm-system/api/sheets.js": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/public-site/index.html" },
    { "source": "/app", "destination": "/crm-system/index.html" },
    { "source": "/app/contracts.html", "destination": "/crm-system/contracts.html" },
    { "source": "/app/financials.html", "destination": "/crm-system/financials.html" },
    { "source": "/api/sheets", "destination": "/crm-system/api/sheets.js" }
  ]
}
