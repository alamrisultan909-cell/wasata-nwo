{
  "version": 2,
  "name": "wasata-platform",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/app", "destination": "/crm-system/dashboard.html" },
    { "source": "/app/(.*)", "destination": "/crm-system/$1" },
    { "source": "/knowledge-base", "destination": "/knowledge-base/index.html" },
    { "source": "/knowledge-base/(.*)", "destination": "/knowledge-base/$1" },
    { "source": "/", "destination": "/public-site/index.html" },
    { "source": "/(.*)", "destination": "/public-site/$1" }
  ]
}
